{
  "framework": "vite",
  "headers": [
    {
      "source": "/lusciouslox/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/favicon.svg",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/inquiry", "destination": "/api/inquiry" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
